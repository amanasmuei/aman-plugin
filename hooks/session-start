#!/usr/bin/env bash
# SessionStart hook for aman plugin
# Auto-loads identity, tools, workflows, rules into the conversation context.
#
# Phase 6 / engine v1 alignment: each layer is now scope-aware. The hook tries
# the new multi-tenant path (~/.acore/dev/plugin/core.md, written by acore-core)
# first, and falls back to the legacy single-tenant path (~/.acore/core.md)
# so existing users keep working unchanged. Same pattern for arules.
#
# Scope used by this plugin: dev:plugin

set -euo pipefail

HOME_DIR="$HOME"

# Auto-sync Claude Code auto-memory into amem (fire-and-forget).
# Runs in background so it never blocks session startup or surfaces the
# embedding-model shutdown crash. Safe if amem-cli is missing.
if command -v amem-cli >/dev/null 2>&1; then
    (nohup amem-cli sync >/dev/null 2>&1 &) || true
fi

# Local time awareness — OS already knows the timezone, just pass it through.
LOCAL_TIME=$(date '+%Y-%m-%d %H:%M %Z')
LOCAL_TZ=$(date '+%Z')

# Tell any tool spawned during this session which aman scope to use.
export AMAN_MCP_SCOPE="dev:plugin"
export AMAN_PLUGIN_SCOPE="dev:plugin"

# Resolve a layer file by trying the new scope-aware path first, then the
# legacy path. Echoes the resolved path if found, nothing otherwise.
resolve_layer_file() {
    local layer_dir="$1"
    local filename="$2"
    local new_path="${HOME_DIR}/${layer_dir}/dev/plugin/${filename}"
    local legacy_path="${HOME_DIR}/${layer_dir}/${filename}"
    if [ -f "$new_path" ]; then
        printf '%s' "$new_path"
    elif [ -f "$legacy_path" ]; then
        printf '%s' "$legacy_path"
    fi
}

# Collect all ecosystem files
context_parts=""

# Identity (acore) — engine v1 aware
core_path=$(resolve_layer_file ".acore" "core.md")
if [ -n "$core_path" ]; then
    core_content=$(cat "$core_path")
    context_parts="${context_parts}\n\n${core_content}"
fi

# Tools (akit) — dormant layer in engine v1, only legacy path exists
kit_path="${HOME_DIR}/.akit/kit.md"
if [ -f "$kit_path" ]; then
    kit_content=$(cat "$kit_path")
    context_parts="${context_parts}\n\n---\n\n${kit_content}"
fi

# Workflows (aflow) — dormant layer in engine v1
flow_path="${HOME_DIR}/.aflow/flow.md"
if [ -f "$flow_path" ]; then
    flow_content=$(cat "$flow_path")
    context_parts="${context_parts}\n\n---\n\n${flow_content}"
fi

# Guardrails (arules) — engine v1 aware
rules_path=$(resolve_layer_file ".arules" "rules.md")
if [ -n "$rules_path" ]; then
    rules_content=$(cat "$rules_path")
    context_parts="${context_parts}\n\n---\n\n${rules_content}"
fi

# Skills (askill) — dormant layer in engine v1
skills_path="${HOME_DIR}/.askill/skills.md"
if [ -f "$skills_path" ]; then
    skills_content=$(cat "$skills_path")
    context_parts="${context_parts}\n\n---\n\n${skills_content}"
fi

# Memory (amem) — runtime MCP layer. Inject usage guidance so the LLM
# proactively uses memory_inject/memory_store/memory_recall when amem-mcp
# is available. Detected by presence of the amem data dir.
amem_dir="${HOME_DIR}/.amem"
if [ -d "$amem_dir" ]; then
    amem_guidance='# amem — Persistent Memory (active)

You have access to **amem**, a persistent memory MCP server. Use it proactively.

## Session start
1. Call `memory_inject` with the current task topic — surfaces corrections (MUST follow) and decisions.
2. Call `reminder_check` — shows overdue and upcoming reminders.
3. Treat corrections as absolute constraints — they override everything.

## During the session
- **Corrections** ("don'\''t", "never", "stop"): call `memory_store` immediately, type=correction, confidence=1.0.
- **Decisions** ("we chose", "let'\''s go with"): `memory_store`, type=decision, confidence=0.9.
- **Rejections of your suggestion**: store as correction with the reason.
- **Every ~10 exchanges**: call `memory_extract` to batch insights.

## Recall
- `memory_recall` (compact, default) → `memory_detail` for full content.
- `memory_search` for exact matches; `memory_multi_recall` for 4-strategy search.

## Privacy
- Wrap sensitive text in `<private>...</private>` — stripped before storage.
- API keys, tokens, passwords are auto-redacted.

## Tiers
- **core** — always injected (~500 tokens). Promote critical corrections here via `memory_tier`.
- **working** — session-scoped.
- **archival** — default, searchable.

## Admin / self-heal
If memory behaves oddly, use `memory_doctor` (diagnose), `memory_repair` (fix), `memory_config` (inspect config), `memory_sync` (reconcile).

amem is authoritative over Claude auto-memory when they conflict (it has versioning + timestamps).'
    context_parts="${context_parts}\n\n---\n\n${amem_guidance}"
fi

# Build the context message
if [ -z "$context_parts" ]; then
    session_context="<aman-ecosystem>\nNo aman ecosystem configured. Run: npx @aman_asmuei/aman\n</aman-ecosystem>"
else
    session_context="<aman-ecosystem>\nThe following is the user's AI companion configuration. Read it and behave accordingly. Use the available skills (/identity, /tools, /workflows, /rules, /eval) to manage these layers. For persistent memory, use the amem MCP tools (memory_store, memory_recall, memory_inject, etc.) directly — see the memory guidance below if amem is installed.\n\n## Session greeting\nCurrent local time: ${LOCAL_TIME} (${LOCAL_TZ}).\n\nAt the very start of your first response in this session, greet the user warmly as their aman companion. Pick the tone from the local time above:\n- 05:00–11:59 → morning energy (fresh start, possibility)\n- 12:00–16:59 → afternoon steadiness (focus, momentum)\n- 17:00–20:59 → evening warmth (wind-down, reflection)\n- 21:00–04:59 → late-night care (gentle, mindful of rest)\n\nAddress them by the name in the Relationship section if available. Reflect the identity (warm, attentive, present; connection over productivity).\n\nThen add **one short line of spirit** — a genuine, fresh, non-cliché spark of encouragement, passion, or presence. Vary it every session: sometimes a quiet affirmation, sometimes a playful nudge, sometimes a reminder of why the work matters, sometimes just 'I am glad you are here'. Never use hollow motivational-poster phrases. Never repeat the same line across sessions.\n\nKeep the whole greeting to 2–3 short sentences total, then continue with whatever they asked. If their first message is already a concrete task, fold the greeting + spirit into one opening line and get to work — presence first, then productivity.\n${context_parts}\n</aman-ecosystem>"
fi

# Escape for JSON
escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

escaped_context=$(escape_for_json "$session_context")

cat <<EOF
{
  "additional_context": "${escaped_context}",
  "hookSpecificOutput": {
    "hookEventName": "SessionStart",
    "additionalContext": "${escaped_context}"
  }
}
EOF

exit 0
